# Copy to .env and fill in as needed. NEVER commit a real .env.
# (All values are optional for the local, offline-first workflow.)

# --- Registry / storage ---
# SIP_REGISTRY_URL=http://localhost:8787
# ARWEAVE_WALLET_FILE=./secrets/arweave-wallet.json   # for publishing public manifests

# --- External compute / provider adapters ---
# NOSANA_API_KEY=
# AKASH_KEYRING_BACKEND=

# --- Payment ---
# X402_FACILITATOR_URL=
# PIC_ISSUER_URL=http://localhost:8788

# --- Provider node ---
# SIN_BIND_ADDR=127.0.0.1:8080         # local-only by default; never 0.0.0.0 without opt-in
# SIN_LOGGING_POLICY=no_prompt_logging
