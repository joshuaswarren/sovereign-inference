{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovereign Inference",
  "version": "0.1.2",
  "identifier": "org.sovereign-inference.desktop",
  "build": {
    "frontendDist": "../../dashboard/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../../dashboard dev",
    "beforeBuildCommand": "pnpm --dir ../../dashboard build"
  },
  "app": {
    "windows": [
      {
        "title": "Sovereign Inference",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:11435 http://127.0.0.1:11435"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Run and route open AI models, sovereignly.",
    "externalBin": ["binaries/sip-openai-proxy"],
    "resources": []
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [{ "name": "binaries/sip-openai-proxy", "sidecar": true, "args": true }]
    }
  }
}
