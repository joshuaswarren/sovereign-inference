{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core webview permissions plus permission to run the bundled proxy sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/sip-openai-proxy", "sidecar": true, "args": true }]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/sip-openai-proxy", "sidecar": true, "args": true }]
    }
  ]
}
